# Ingestion source
DATA_API_URL=http://149.40.228.124:6500/records
INGEST_INTERVAL_SECONDS=60

# Model and retraining thresholds
MODEL_ACCURACY_THRESHOLD=0.80
MAX_TRAINING_ITERATIONS=10
DRIFT_THRESHOLD=0.25
RETRAIN_MIN_NEW_RECORDS=200

# Serving
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker / registry
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_token
DOCKER_IMAGE_NAME=mlops-project
DOCKER_IMAGE_TAG=latest

# AWS EC2 deployment
EC2_HOST=
EC2_PUBLIC_IP=
EC2_USER=ubuntu
EC2_SSH_KEY_PATH=~/.ssh/ec2_key.pem

# Alerting
SLACK_WEBHOOK_URL=
